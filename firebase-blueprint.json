{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task created by a user to track their daily activities",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique task ID" },
        "title": { "type": "string", "description": "The title of the task" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"], "description": "Task priority level" },
        "estimatedMinutes": { "type": "integer", "description": "Estimated time to complete in minutes" },
        "category": { "type": "string", "description": "The category/group of the task" },
        "status": { "type": "string", "enum": ["not_started", "in_progress", "completed"], "description": "Current state of the task" },
        "createdAt": { "type": "integer", "description": "Timestamp of creation" },
        "userId": { "type": "string", "description": "The owner's Firebase Authentication UID" }
      },
      "required": ["id", "title", "priority", "estimatedMinutes", "category", "status", "createdAt", "userId"]
    },
    "TaikinRecord": {
      "title": "TaikinRecord",
      "description": "A daily clock-in/clock-out record for time tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique record ID" },
        "date": { "type": "string", "description": "The date of the shift (YYYY-MM-DD)" },
        "clockIn": { "type": "string", "description": "The clock-in time string (HH:MM)" },
        "clockOut": { "type": "string", "description": "The clock-out time string (HH:MM)" },
        "workMinutes": { "type": "integer", "description": "Calculated working minutes, excluding break" },
        "overtimeMinutes": { "type": "integer", "description": "Calculated overtime minutes beyond guidelines" },
        "userId": { "type": "string", "description": "The owner's Firebase Authentication UID" }
      },
      "required": ["id", "date", "clockIn", "clockOut", "workMinutes", "overtimeMinutes", "userId"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "A syncable or custom created user calendar event",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The event ID" },
        "summary": { "type": "string", "description": "Event summary/title" },
        "description": { "type": "string", "description": "Event detailed description" },
        "location": { "type": "string", "description": "Event location info" },
        "userId": { "type": "string", "description": "The owner's Firebase Authentication UID" },
        "start": {
          "type": "object",
          "properties": {
            "dateTime": { "type": "string" },
            "date": { "type": "string" }
          }
        },
        "end": {
          "type": "object",
          "properties": {
            "dateTime": { "type": "string" },
            "date": { "type": "string" }
          }
        }
      },
      "required": ["id", "summary", "userId", "start", "end"]
    }
  },
  "firestore": {
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Collection where users store their private tasks"
    },
    "taikinRecords/{recordId}": {
      "schema": "TaikinRecord",
      "description": "Collection where users store their shift attendance logs"
    },
    "customCalendarEvents/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Collection where users store their optional manual calendar events"
    }
  }
}
